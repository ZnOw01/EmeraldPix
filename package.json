{
  "name": "emeraldpix",
  "version": "3.3.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "build:fast": "vite build",
    "build:watch": "cross-env VITE_BUILD_WATCH=true vite build --watch --mode development",
    "dev:ext": "npm run build:watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"*.config.ts\"",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/chrome": "^0.0.322",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.5.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "svelte": "^5.50.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "jspdf": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=22"
  }
}
